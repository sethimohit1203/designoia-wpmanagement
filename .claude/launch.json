{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "node",
      "runtimeArgs": ["src/server.js"],
      "cwd": "backend",
      "port": 5000
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "--port", "5173"],
      "cwd": "frontend",
      "port": 5173
    },
    {
      "name": "seo-suite",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "seo-suite-link",
      "port": 3000
    }
  ]
}
